# ---------------------------------------------------------------------------
# Nemo — variables d'environnement dev
# Copie en .env.local dans chaque app qui en a besoin, ou charge depuis
# un .env racine avec `pnpm dlx dotenv-cli -- pnpm dev` si tu préfères.
# ---------------------------------------------------------------------------

# Infra locale (via docker compose -f docker-compose.dev.yml up -d)
DATABASE_URL=postgresql://nemo:nemo@localhost:5432/nemo
REDIS_URL=redis://localhost:6379

# Ports des services
PORT=3001             # game-engine (Fastify)
WS_PORT=3002          # ws-gateway (uWebSockets.js)
WEB_ORIGIN=http://localhost:3000

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE=http://localhost:3001
NEXT_PUBLIC_WS_BASE=ws://localhost:3002
# Laisser vide = mode démo (simulateur local, pas de WS).
# À passer à "1" quand tu veux connecter la carte au ws-gateway.
NEXT_PUBLIC_WS_LIVE=1

# --- Pipeline météo ---
# fixture = utilise packages/game-engine/fixtures/weather-grid.json (aucun Redis requis)
# noaa    = consomme weather:grid:* depuis Redis (alimenté par apps/weather-engine)
NEMO_WEATHER_MODE=fixture

# --- Cognito (Phase 4, vide = stub dev-login actif) ---
# COGNITO_REGION=eu-west-3
# COGNITO_USER_POOL_ID=eu-west-3_XXXXXXXXX
# COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxx

# --- Stripe (Phase 4) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
