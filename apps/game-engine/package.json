{
  "name": "@nemo/game-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:e2e": "tsx src/test/e2e-tick.ts",
    "test:e2e:phase2": "tsx src/test/e2e-phase2.ts",
    "test:e2e:segments": "tsx src/test/e2e-segments.ts",
    "bench:tick": "tsx src/test/bench-tick.ts",
    "bench:broadcast": "tsx src/test/bench-broadcast.ts",
    "build:fixture": "tsx src/weather/build-fixture.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nemo/shared-types": "workspace:*",
    "@nemo/polar-lib": "workspace:*",
    "@nemo/game-balance": "workspace:*",
    "fastify": "^5.1.0",
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5",
    "pino": "^9.5.0",
    "@turf/boolean-point-in-polygon": "^7.1.0",
    "@turf/bbox": "^7.1.0",
    "@turf/helpers": "^7.1.0",
    "@msgpack/msgpack": "^3.0.0",
    "ioredis": "^5.4.2",
    "jose": "^5.9.6",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "drizzle-kit": "^0.28.1",
    "typescript": "^5.7.2",
    "tsx": "^4.19.0"
  }
}
