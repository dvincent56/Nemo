{
  "name": "nemo",
  "version": "0.1.0",
  "private": true,
  "description": "Nemo — jeu de voile offshore PWA, concurrent Virtual Regatta",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "e2e:tick": "pnpm --filter @nemo/game-engine test:e2e",
    "e2e:phase2": "pnpm --filter @nemo/game-engine test:e2e:phase2",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "infra:logs": "docker compose -f docker-compose.dev.yml logs -f",
    "db:push": "pnpm --filter @nemo/game-engine db:push",
    "db:migrate": "pnpm --filter @nemo/game-engine db:migrate",
    "db:studio": "pnpm --filter @nemo/game-engine db:studio",
    "fixture": "pnpm --filter @nemo/game-engine build:fixture",
    "prepare": "husky"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  }
}
